class LearningRouter:
    def __init__(self):
        self.scores = {
            "research": 1.0,
            "analyze": 1.0,
            "act": 1.0
        }

    def choose(self, task_type):
        base = self.scores.get(task_type, 1.0)
        return base + random.uniform(-0.2, 0.2)

    def update(self, task_type, reward):
        self.scores[task_type] = max(0.1, self.scores.get(task_type, 1.0) + reward)import random

class Agent:
    def __init__(self, name, role):
        self.name = name
        self.role = role
        self.energy = 100

    def act(self):
        cost = random.randint(5, 15)
        gain = random.randint(10, 25)
        self.energy += gain - cost
        return {
            "agent": self.name,
            "role": self.role,
            "cost": cost,
            "gain": gain,
            "energy": self.energy
        }class TaskGraph:
    def __init__(self):
        self.nodes = []

    def add(self, task):
        self.nodes.append(task)

    def run(self):
        results = []
        for n in self.nodes:
            results.append(n())
        return resultsclass EcoSystem:
    def __init__(self):
        self.pool = 0

    def decompose(self, result):
        self.pool += result.get("gain", 0)

    def recycle(self):
        boost = self.pool // 10
        self.pool = self.pool % 10
        return boostclass Executor:
