from eco import EcoSystem
from memory import Memory

router = LearningRouter()
executor = Executor()
eco = EcoSystem()
memory = Memory()

agents = [
    Agent("A1", "research"),
    Agent("A2", "analyze"),
    Agent("A3", "act")
]

def run_cycle():
    print("\n--- CYCLE START ---")

    for agent in agents:
        score = router.choose(agent.role)
        result = executor.run(agent)

        eco.decompose(result)
        memory.add(result)

        reward = (result["gain"] - result["cost"]) / 10
        router.update(agent.role, reward)

        print(result, "score:", round(score, 2))

    boost = eco.recycle()
    for a in agents:
        a.energy += boost

    print("Eco pool boost:", boost)
    print("Memory size:", len(memory.get_all()))
    print("--- CYCLE END ---\n")


if __name__ == "__main__":
    for i in range(5):
        run_cycle()python main.py
