class AdaptiveRouter:
    def __init__(self, memory):
        self.memory = memory

    def select(self, agents):
        scores = [(a, self.memory.get_score(a.name)) for a in agents]

        total = sum(s for _, s in scores)
        r = random.random() * total

        upto = 0
        for agent, score in scores:
            upto += score
            if upto >= r:
                return agent

        return agents[0]import sqlite3

class Storage:
    def __init__(self, db="runtime.db"):
        self.conn = sqlite3.connect(db)
        self._init()

    def _init(self):
