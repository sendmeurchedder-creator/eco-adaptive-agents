    def __init__(self):
        self.nodes = {}
        self.edges = {}

    def add_task(self, name, agents, deps=None):
        self.nodes[name] = agents
        self.edges[name] = deps or []

    def ready(self, completed):
        return [
            n for n, deps in self.edges.items()
            if n not in completed and all(d in completed for d in deps)
        ]import threading

class Executor:
    def run_parallel(self, tasks):
        results = {}
        lock = threading.Lock()

        def run(name, fn):
            res = fn()
            with lock:
                results[name] = res

        threads = []
        for name, fn in tasks.items():
            t = threading.Thread(target=run, args=(name, fn))
            threads.append(t)
            t.start()

        for t in threads:
            t.join()

        return resultsclass EcoMetrics:
    def __init__(self):
        self.counts = {}

    def update(self, agent):
        self.counts[agent] = self.counts.get(agent, 0) + 1

    def diversity(self):
        if not self.counts:
            return 0

        vals = list(self.counts.values())
        avg = sum(vals) / len(vals)
        return 1 - (max(vals) - min(vals)) / (avg + 1)from memory import MemoryStore
