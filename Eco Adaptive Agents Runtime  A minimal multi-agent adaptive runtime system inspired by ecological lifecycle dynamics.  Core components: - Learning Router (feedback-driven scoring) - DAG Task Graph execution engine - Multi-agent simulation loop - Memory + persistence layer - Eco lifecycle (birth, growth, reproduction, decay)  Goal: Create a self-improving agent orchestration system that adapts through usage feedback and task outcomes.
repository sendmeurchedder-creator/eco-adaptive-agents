def run():
    memory = MemoryStore()
    eco = EcoMetrics()
    store = Storage()
    router = AdaptiveRouter(memory)
    executor = Executor()

    agents = [
        FastAgent(),
        AccurateAgent(),
        CreativeAgent()
    ]

    graph = TaskGraph()
    graph.add_task("research", agents)
    graph.add_task("analysis", agents, deps=["research"])
    graph.add_task("summary", agents, deps=["analysis"])

    completed = set()

    while len(completed) < len(graph.nodes):
        ready = graph.ready(completed)

        if not ready:
            break

        batch = {}

        for task in ready:
            agent = router.select(graph.nodes[task])

            def fn(a=agent, t=task):
                return a.run(t)

            batch[task] = fn

        results = executor.run_parallel(batch)

        for task, success in results.items():
            agent = "unknown"

            memory.update(agent, success)
            eco.update(agent)
            store.log(task, agent, success)

            print(task, success)

            if success:
                completed.add(task)

    print("Diversity:", eco.diversity())


